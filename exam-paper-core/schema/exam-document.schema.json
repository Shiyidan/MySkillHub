{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.codex/exam-paper-core/schema/exam-document.schema.json",
  "title": "英文试卷统一文档契约",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "document_type",
    "source_hash",
    "validation_status",
    "question_fingerprint_version",
    "locale",
    "metadata",
    "questions"
  ],
  "properties": {
    "contract_version": {"const": "3.2.0"},
    "document_type": {"enum": ["parsed_exam", "generated_exam", "assembled_exam"]},
    "source_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "validation_status": {"enum": ["draft", "passed", "failed"]},
    "question_fingerprint_version": {"const": "2"},
    "locale": {
      "type": "object",
      "additionalProperties": false,
      "required": ["interface_language", "question_language", "explanation_language"],
      "properties": {
        "interface_language": {"const": "zh-CN"},
        "question_language": {"const": "en"},
        "explanation_language": {"const": "zh-CN"}
      }
    },
    "metadata": {
      "type": "object",
      "required": ["exam_type", "year", "source_files"],
      "properties": {
        "exam_type": {"type": "string", "minLength": 1},
        "year": {"type": ["string", "integer"]},
        "source_files": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "title": {"type": "string"},
        "subject": {"type": "string"},
        "corpus_group": {"type": "string"},
        "syllabus_version": {"type": "string"},
        "source_exam_types": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "target_exam": {"type": "string"},
        "assembly": {
          "type": "object",
          "additionalProperties": false,
          "required": ["target_exam", "modules", "required_module", "source_document", "assembly_rule", "paper_note", "syllabus_root", "official_full_test_time_minutes", "total_suggested_time_minutes", "sections", "scoring"],
          "properties": {
            "target_exam": {"const": "ESAT"},
            "modules": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {"enum": ["Mathematics 1", "Biology", "Chemistry", "Physics", "Mathematics 2"]}
            },
            "required_module": {"const": "Mathematics 1"},
            "source_document": {"type": "string", "minLength": 1},
            "assembly_rule": {"type": "string", "minLength": 10},
            "paper_note": {"type": "string", "minLength": 20},
            "syllabus_root": {
              "type": "object",
              "additionalProperties": false,
              "required": ["code", "label", "source_file"],
              "properties": {
                "code": {"const": "100000"},
                "label": {"type": "string", "minLength": 1},
                "source_file": {"const": "esat_syllabus.json"}
              }
            },
            "official_full_test_time_minutes": {"type": "integer", "minimum": 40},
            "total_suggested_time_minutes": {"type": "integer", "minimum": 40},
            "sections": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "module",
                  "module_code",
                  "module_label",
                  "section_order",
                  "official_question_count",
                  "official_time_minutes",
                  "suggested_time_minutes",
                  "target_question_count",
                  "actual_question_count",
                  "scoring_group",
                  "diagnostic_status",
                  "diagnostic_flags",
                  "diagnostic_confidence",
                  "coverage_summary",
                  "syllabus_coverage",
                  "time_note",
                  "module_note"
                ],
                "properties": {
                  "module": {"enum": ["Mathematics 1", "Biology", "Chemistry", "Physics", "Mathematics 2"]},
                  "module_code": {"type": "string", "pattern": "^[0-9]{6}$"},
                  "module_label": {"type": "string", "minLength": 1},
                  "section_order": {"type": "integer", "minimum": 1},
                  "official_question_count": {"const": 27},
                  "official_time_minutes": {"const": 40},
                  "suggested_time_minutes": {"const": 40},
                  "target_question_count": {"type": "integer", "minimum": 1},
                  "actual_question_count": {"type": "integer", "minimum": 0},
                  "scoring_group": {"enum": ["Mathematics 1", "Biology", "Chemistry", "Physics", "Mathematics 2"]},
                  "diagnostic_status": {"enum": ["sufficient", "underfilled", "overfilled", "narrow_coverage", "source_skewed", "mixed"]},
                  "diagnostic_flags": {
                    "type": "array",
                    "items": {"enum": ["underfilled", "overfilled", "narrow_coverage", "source_skewed", "mixed"]}
                  },
                  "diagnostic_confidence": {"enum": ["high", "medium", "low"]},
                  "coverage_summary": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["available_question_count", "selected_question_count", "syllabus_families", "difficulty_distribution", "source_exam_types"],
                    "properties": {
                      "available_question_count": {"type": "integer", "minimum": 0},
                      "selected_question_count": {"type": "integer", "minimum": 0},
                      "syllabus_families": {"type": "array", "items": {"type": "string", "minLength": 1}},
                      "difficulty_distribution": {"type": "object"},
                      "source_exam_types": {"type": "object"}
                    }
                  },
                  "syllabus_coverage": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["selected_question_codes", "syllabus_codes", "syllabus_items", "unmatched_syllabus_codes", "coverage_note"],
                    "properties": {
                      "selected_question_codes": {"type": "array", "items": {"type": "string", "minLength": 1}},
                      "syllabus_codes": {"type": "array", "items": {"type": "string", "pattern": "^[0-9]{6}$"}},
                      "syllabus_items": {"type": "array", "items": {"$ref": "#/$defs/syllabus_item"}},
                      "unmatched_syllabus_codes": {"type": "array", "items": {"type": "string", "minLength": 1}},
                      "coverage_note": {"type": "string", "minLength": 10}
                    }
                  },
                  "time_note": {"type": "string", "minLength": 20},
                  "module_note": {"type": "string", "minLength": 20}
                }
              }
            },
            "scoring": {
              "type": "object",
              "additionalProperties": false,
              "required": ["mode", "raw_per_question_score", "negative_marking", "raw_score_reporting", "official_reported_scale", "official_decimal_places", "official_scaling_method", "official_scaled_score_available", "diagnostic_score_note"],
              "properties": {
                "mode": {"const": "by_module"},
                "raw_per_question_score": {"const": 1},
                "negative_marking": {"const": false},
                "raw_score_reporting": {"const": "raw_and_percentage_by_module"},
                "official_reported_scale": {"const": "1.0-9.0"},
                "official_decimal_places": {"const": 1},
                "official_scaling_method": {"type": "string", "minLength": 10},
                "official_scaled_score_available": {"const": false},
                "diagnostic_score_note": {"type": "string", "minLength": 30}
              }
            }
          }
        }
      },
      "additionalProperties": false
    },
    "questions": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/question"}
    }
  },
  "$defs": {
    "content_block": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "content"],
          "properties": {
            "type": {"enum": ["text", "latex"]},
            "content": {"type": "string", "minLength": 1}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "image_id"],
          "properties": {
            "type": {"const": "image_ref"},
            "image_id": {"type": "string", "minLength": 1}
          }
        }
      ]
    },
    "locator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file", "page"],
      "properties": {
        "file": {"type": "string", "minLength": 1},
        "page": {"type": "integer", "minimum": 1}
      }
    },
    "syllabus_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "label",
        "module",
        "module_code",
        "module_label",
        "parent_code",
        "parent_label",
        "path_codes",
        "path_labels"
      ],
      "properties": {
        "code": {"type": "string", "pattern": "^[0-9]{6}$"},
        "label": {"type": "string", "minLength": 1},
        "module": {"type": "string", "minLength": 1},
        "module_code": {"type": "string", "pattern": "^[0-9]{6}$"},
        "module_label": {"type": "string", "minLength": 1},
        "parent_code": {"type": "string", "pattern": "^[0-9]{6}$"},
        "parent_label": {"type": "string", "minLength": 1},
        "path_codes": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^[0-9]{6}$"}},
        "path_labels": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
      }
    },
    "question": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "number",
        "title",
        "options",
        "answer",
        "images",
        "examType",
        "source_examType",
        "year",
        "questionNumber",
        "subject",
        "subject_code",
        "topic",
        "topic_code",
        "question_type",
        "difficulty",
        "knowledge_points",
        "is_ai_generated",
        "learning_analysis",
        "explanation",
        "fingerprint",
        "syllabus_tags",
        "diagram",
        "target_exam_scope",
        "source"
      ],
      "properties": {
        "code": {"type": "string", "minLength": 1},
        "number": {"type": ["string", "integer"]},
        "title": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/content_block"}},
        "options": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["label", "content"],
            "properties": {
              "label": {"type": "string", "minLength": 1},
              "content": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/content_block"}}
            }
          }
        },
        "answer": {},
        "images": {"type": "array"},
        "examType": {"type": "string", "minLength": 1},
        "source_examType": {"type": "string", "minLength": 1},
        "year": {"type": ["string", "integer"]},
        "questionNumber": {"type": ["string", "integer"]},
        "subject": {"type": "string", "minLength": 1},
        "subject_code": {"type": "string", "minLength": 1},
        "topic": {"type": "string", "minLength": 1},
        "topic_code": {"type": "string", "minLength": 1},
        "question_type": {"enum": ["multiple_choice", "free_response"]},
        "difficulty": {"enum": ["easy", "medium", "hard"]},
        "knowledge_points": {"type": "array", "minItems": 1},
        "is_ai_generated": {"type": "boolean"},
        "learning_analysis": {"type": "object"},
        "explanation": {"type": "string", "minLength": 80},
        "fingerprint": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "syllabus_tags": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "diagram": {"type": ["object", "null"]},
        "assembled_section": {
          "type": "object",
          "additionalProperties": false,
          "required": ["module", "module_code", "module_label", "section_order", "question_order", "scoring_group", "syllabus_items"],
          "properties": {
            "module": {"enum": ["Mathematics 1", "Biology", "Chemistry", "Physics", "Mathematics 2"]},
            "module_code": {"type": "string", "pattern": "^[0-9]{6}$"},
            "module_label": {"type": "string", "minLength": 1},
            "section_order": {"type": "integer", "minimum": 1},
            "question_order": {"type": "integer", "minimum": 1},
            "scoring_group": {"enum": ["Mathematics 1", "Biology", "Chemistry", "Physics", "Mathematics 2"]},
            "syllabus_items": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/syllabus_item"}}
          }
        },
        "target_exam_scope": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "target_exam",
            "status",
            "modules",
            "primary_module",
            "primary_module_code",
            "primary_module_label",
            "syllabus_codes",
            "syllabus_items",
            "exclusion_reasons",
            "evidence",
            "review_status"
          ],
          "properties": {
            "target_exam": {"type": "string", "minLength": 1},
            "status": {"enum": ["in_scope", "out_of_scope", "partially_in_scope", "unknown"]},
            "modules": {
              "type": "array",
              "items": {"type": "string", "minLength": 1}
            },
            "primary_module": {
              "oneOf": [
                {"type": "string", "minLength": 1},
                {"type": "null"}
              ]
            },
            "primary_module_code": {
              "oneOf": [
                {"type": "string", "minLength": 1},
                {"type": "null"}
              ]
            },
            "primary_module_label": {
              "oneOf": [
                {"type": "string", "minLength": 1},
                {"type": "null"}
              ]
            },
            "syllabus_codes": {"type": "array", "items": {"type": "string", "pattern": "^[0-9]{6}$"}},
            "syllabus_items": {"type": "array", "items": {"$ref": "#/$defs/syllabus_item"}},
            "exclusion_reasons": {"type": "array", "items": {"type": "string", "minLength": 1}},
            "evidence": {"type": "string", "minLength": 10},
            "review_status": {"enum": ["unchecked", "reviewed", "needs_review"]}
          }
        },
        "source": {
          "oneOf": [
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["question", "answer", "solution", "evidence_packet"],
              "properties": {
                "question": {"$ref": "#/$defs/locator"},
                "answer": {"$ref": "#/$defs/locator"},
                "solution": {"oneOf": [{"$ref": "#/$defs/locator"}, {"type": "null"}]},
                "evidence_packet": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["path", "sha256"],
                  "properties": {
                    "path": {"type": "string", "minLength": 1},
                    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
                  }
                }
              }
            },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["source_question_id", "source_fingerprint", "generation_blueprint"],
              "properties": {
                "source_question_id": {"type": "string", "minLength": 1},
                "source_fingerprint": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
                "generation_blueprint": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "retained_knowledge_point",
                    "source_deconstruction",
                    "structural_transformation",
                    "changed_reasoning_structure",
                    "changed_context",
                    "changed_values",
                    "difficulty_reassessment",
                    "diagram_generation_spec",
                    "novelty_rationale"
                  ],
                  "properties": {
                    "retained_knowledge_point": {"type": "string", "minLength": 1},
                    "source_deconstruction": {"type": "string", "minLength": 40},
                    "structural_transformation": {"type": "string", "minLength": 40},
                    "changed_reasoning_structure": {"type": "string", "minLength": 20},
                    "changed_context": {"type": "string", "minLength": 1},
                    "changed_values": {"type": "string", "minLength": 1},
                    "difficulty_reassessment": {"type": "string", "minLength": 40},
                    "diagram_generation_spec": {"type": "string", "minLength": 40},
                    "novelty_rationale": {"type": "string", "minLength": 20}
                  }
                }
              }
            }
          ]
        }
      }
    }
  }
}
