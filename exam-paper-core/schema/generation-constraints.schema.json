{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.codex/exam-paper-core/schema/generation-constraints.schema.json",
  "title": "英文试卷生成约束",
  "type": "object",
  "additionalProperties": false,
  "required": ["question_count"],
  "properties": {
    "question_count": {"type": "integer", "minimum": 1},
    "exam_type": {"type": "string", "minLength": 1},
    "year": {"type": ["string", "integer"]},
    "title": {"type": "string", "minLength": 1},
    "question_type_counts": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": false,
      "properties": {
        "multiple_choice": {"type": "integer", "minimum": 1},
        "free_response": {"type": "integer", "minimum": 1}
      }
    },
    "difficulty_counts": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": false,
      "properties": {
        "easy": {"type": "integer", "minimum": 1},
        "medium": {"type": "integer", "minimum": 1},
        "hard": {"type": "integer", "minimum": 1},
        "composite": {"type": "integer", "minimum": 1}
      }
    },
    "module_counts": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {"type": "integer", "minimum": 1}
    },
    "primary_syllabus_codes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "exclude_source_question_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    }
  }
}
