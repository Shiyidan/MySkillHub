{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.codex/exam-paper-core/schema/project-diagnostic-paper.schema.json",
  "title": "QuizTestDemo ESAT Legacy Diagnostic Paper",
  "description": "由内部 assembled_exam 导出的单套自包含 ESAT legacy 诊断卷，可直接提交到 /api/papers/import-json。",
  "type": "object",
  "additionalProperties": false,
  "required": ["code", "metadata", "questions"],
  "properties": {
    "code": {"type": "string", "minLength": 1},
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["paperName", "year", "duration", "examType", "paperType", "totalQuestions", "remarks"],
      "properties": {
        "paperName": {"type": "string", "minLength": 1},
        "year": {"type": "integer"},
        "duration": {"type": "integer", "minimum": 1},
        "examType": {"const": "ESAT"},
        "paperType": {"const": "mockPaper"},
        "totalQuestions": {"type": "integer", "minimum": 1},
        "remarks": {"type": "string", "minLength": 1}
      }
    },
    "questions": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/question"}
    }
  },
  "$defs": {
    "content_block": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "text"],
          "properties": {
            "type": {"const": "paragraph"},
            "text": {"type": "string", "minLength": 1}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "image_id"],
          "properties": {
            "type": {"const": "image_ref"},
            "image_id": {"type": "string", "minLength": 1}
          }
        }
      ]
    },
    "option": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "text"],
      "properties": {
        "label": {"type": "string", "minLength": 1},
        "text": {"type": "string"},
        "image_id": {"type": "string", "minLength": 1}
      }
    },
    "image": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "type", "alt", "svg"],
          "properties": {
            "id": {"type": "string", "minLength": 1},
            "type": {"const": "svg"},
            "alt": {"type": "string", "minLength": 1},
            "svg": {"type": "string", "minLength": 1}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "type", "alt", "src"],
          "properties": {
            "id": {"type": "string", "minLength": 1},
            "type": {"const": "image"},
            "alt": {"type": "string", "minLength": 1},
            "src": {"type": "string", "pattern": "^data:image/"}
          }
        }
      ]
    },
    "point": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "label", "role"],
      "properties": {
        "code": {"type": "string", "minLength": 1},
        "label": {"type": "string", "minLength": 1},
        "role": {"enum": ["primary", "secondary"]}
      }
    },
    "learning_analysis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["exam_focus", "solution", "review_guidance"],
      "properties": {
        "exam_focus": {"type": "string", "minLength": 1},
        "solution": {"type": "string", "minLength": 1},
        "review_guidance": {"type": "string", "minLength": 1}
      }
    },
    "question": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "number",
        "title",
        "content_blocks",
        "options",
        "answer",
        "images",
        "examType",
        "source_examType",
        "year",
        "subject",
        "subject_code",
        "topic",
        "topic_code",
        "question_type",
        "difficulty",
        "syllabus_points",
        "knowledge_points",
        "is_ai_generated",
        "learning_analysis"
      ],
      "properties": {
        "code": {"type": "string", "minLength": 1},
        "number": {"type": "integer", "minimum": 1},
        "title": {"type": "string", "minLength": 1},
        "content_blocks": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/content_block"}},
        "options": {"type": "array", "minItems": 2, "items": {"$ref": "#/$defs/option"}},
        "answer": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "images": {"type": "array", "items": {"$ref": "#/$defs/image"}},
        "examType": {"const": "ESAT"},
        "source_examType": {"enum": ["ENGAA", "NSAA"]},
        "year": {"type": "integer"},
        "subject": {"type": "string", "minLength": 1},
        "subject_code": {"type": "string", "minLength": 1},
        "topic": {"type": "string", "minLength": 1},
        "topic_code": {"type": "string", "minLength": 1},
        "question_type": {"enum": ["single_choice", "multiple_choice", "short_answer"]},
        "difficulty": {"enum": ["easy", "medium", "hard"]},
        "syllabus_points": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/point"}},
        "knowledge_points": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/point"}},
        "is_ai_generated": {"const": false},
        "learning_analysis": {"$ref": "#/$defs/learning_analysis"}
      }
    }
  }
}
