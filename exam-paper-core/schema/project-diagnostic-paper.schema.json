{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oxbridge-ai.local/schema/project-diagnostic-paper.schema.json",
  "title": "Unified ESAT and TMUA project diagnostic paper",
  "type": "object",
  "additionalProperties": false,
  "required": ["metadata", "sections"],
  "properties": {
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "title",
        "examType",
        "year",
        "paperType",
        "assemblyType",
        "deliveryMode",
        "remarks"
      ],
      "properties": {
        "code": {"type": "string", "minLength": 1},
        "title": {"type": "string", "minLength": 1},
        "examType": {"enum": ["ESAT", "TMUA"]},
        "year": {"type": "integer"},
        "paperType": {"enum": ["realPaper", "mockPaper", "aiPaper"]},
        "assemblyType": {"enum": ["legacy_equivalent", "original"]},
        "deliveryMode": {"const": "section_sequence"},
        "remarks": {"type": "string", "minLength": 1}
      }
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/section"}
    }
  },
  "$defs": {
    "section": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "sectionType",
        "order",
        "questions"
      ],
      "properties": {
        "code": {"type": "string", "minLength": 1},
        "sectionType": {"enum": ["subject", "paper"]},
        "order": {"type": "integer", "minimum": 1},
        "questions": {
          "type": "array",
          "items": {"$ref": "#/$defs/question"}
        }
      }
    },
    "contentBlock": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "text"],
          "properties": {
            "type": {"const": "paragraph"},
            "text": {"type": "string", "minLength": 1},
            "align": {"enum": ["left", "center", "right"]}
          }
        },
        {
          "type": "object",
          "additionalProperties": true,
          "required": ["type", "image_id"],
          "properties": {
            "type": {"const": "image_ref"},
            "image_id": {"type": "string", "minLength": 1},
            "alt": {"type": "string"}
          }
        }
      ]
    },
    "option": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "text"],
      "properties": {
        "label": {"type": "string", "minLength": 1},
        "text": {"type": "string"},
        "image_id": {"type": "string", "minLength": 1}
      }
    },
    "image": {
      "type": "object",
      "required": ["id", "type", "alt"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "type": {"enum": ["svg", "image"]},
        "alt": {"type": "string"},
        "svg": {"type": "string"},
        "src": {"type": "string"}
      }
    },
    "knowledgePoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "label", "role"],
      "properties": {
        "code": {"type": "string", "minLength": 1},
        "label": {"type": "string", "minLength": 1},
        "role": {"enum": ["primary", "secondary"]}
      }
    },
    "classification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["subject", "subjectCode", "topic", "topicCode", "knowledgePoints"],
      "properties": {
        "subject": {"type": "string", "minLength": 1},
        "subjectCode": {"type": "string", "minLength": 1},
        "topic": {"type": "string"},
        "topicCode": {"type": "string"},
        "knowledgePoints": {
          "type": "array",
          "items": {"$ref": "#/$defs/knowledgePoint"}
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["examType", "year", "sectionCode", "questionNumber"],
      "properties": {
        "examType": {"type": "string", "minLength": 1},
        "year": {"type": "integer"},
        "sectionCode": {"type": "string", "minLength": 1},
        "questionNumber": {"type": ["integer", "string"]}
      }
    },
    "learningAnalysis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["correctSolution", "examFocus", "commonErrorCauses", "reviewGuidance"],
      "properties": {
        "correctSolution": {"type": "string"},
        "examFocus": {"type": "string"},
        "commonErrorCauses": {
          "type": "array",
          "items": {"type": "string"}
        },
        "reviewGuidance": {"type": "string"}
      }
    },
    "question": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "number",
        "title",
        "contentBlocks",
        "options",
        "answer",
        "images",
        "questionType",
        "difficulty",
        "classification",
        "source",
        "learningAnalysis"
      ],
      "properties": {
        "code": {"type": "string", "minLength": 1},
        "number": {"type": "integer", "minimum": 1},
        "title": {"type": "string", "minLength": 1},
        "contentBlocks": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/contentBlock"}
        },
        "options": {
          "type": "array",
          "items": {"$ref": "#/$defs/option"}
        },
        "answer": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string"}
        },
        "images": {
          "type": "array",
          "items": {"$ref": "#/$defs/image"}
        },
        "questionType": {"enum": ["single_choice", "multiple_choice", "short_answer"]},
        "difficulty": {"enum": ["easy", "medium", "hard", "composite"]},
        "classification": {"$ref": "#/$defs/classification"},
        "source": {"$ref": "#/$defs/source"},
        "learningAnalysis": {"$ref": "#/$defs/learningAnalysis"}
      }
    }
  }
}
