{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.codex.skills/exam-paper-recognizer/project-question.schema.json",
  "title": "Clean Project Exam Questions",
  "description": "项目最终入库/渲染使用的清爽版试题 JSON。根层级只允许 questions；调试信息、来源追踪、答案匹配日志、taxonomy 说明和解析过程元数据不得进入 final JSON。",
  "type": "object",
  "required": ["questions"],
  "additionalProperties": false,
  "properties": {
    "questions": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/question"}
    }
  },
  "$defs": {
    "question": {
      "type": "object",
      "required": ["number", "title", "options", "answer", "images"],
      "additionalProperties": false,
      "properties": {
        "number": {"type": "integer", "minimum": 1},
        "title": {"type": "string"},
        "content_blocks": {
          "type": "array",
          "description": "按原题阅读顺序保存题干段落、公式和题中图片引用。",
          "items": {"$ref": "#/$defs/content_block"}
        },
        "options": {
          "type": "array",
          "items": {"$ref": "#/$defs/option"}
        },
        "answer": {
          "type": "array",
          "items": {"type": "string"}
        },
        "images": {
          "type": "array",
          "items": {"$ref": "#/$defs/image"}
        },
        "subject": {
          "type": "string",
          "description": "题目所属科目，例如 Mathematics 1, Mathematics 2, Physics, Chemistry, Biology。"
        },
        "subject_code": {
          "type": "string",
          "description": "对应项目左侧简版考纲 tree 的科目节点 code，例如 110000。"
        },
        "topic": {
          "type": "string",
          "description": "对应项目左侧简版考纲 tree 的 topic 节点 label，例如 Number & Arithmetic (算术与数)。"
        },
        "topic_code": {
          "type": "string",
          "description": "对应项目左侧简版考纲 tree 的 topic 节点 code，例如 111000。"
        },
        "question_type": {
          "type": "string",
          "enum": [
            "single_choice",
            "multiple_choice",
            "numeric",
            "formula_rearrangement",
            "graph_interpretation",
            "geometry",
            "circuit_analysis",
            "mechanics",
            "data_table",
            "word_problem",
            "unknown"
          ]
        },
        "difficulty": {
          "type": "string",
          "enum": ["easy", "medium", "hard", "composite", "unknown"],
          "description": "只保留难度结果；中文展示由前端映射。"
        },
        "syllabus_points": {
          "type": "array",
          "description": "对应项目左侧简版考纲 tree 的叶子节点，用于前端筛选。",
          "items": {"$ref": "#/$defs/point"}
        },
        "knowledge_points": {
          "type": "array",
          "description": "对应 medium/official 考纲 tree 的叶子节点，用于细化知识点、诊断报告和后续生题。",
          "items": {"$ref": "#/$defs/point"}
        },
        "skills": {
          "type": "array",
          "items": {"type": "string"}
        },
        "learning_analysis": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "exam_focus": {
              "type": "string",
              "description": "中文考察点，默认不超过 50 个中文字符。"
            },
            "solution": {
              "type": "string",
              "description": "中文题目解析，默认不超过 50 个中文字符，公式使用 Markdown + LaTeX。"
            },
            "review_guidance": {
              "type": "string",
              "description": "中文复习引导，默认不超过 50 个中文字符。"
            }
          }
        },
        "generation_profile": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "can_generate_similar": {"type": "boolean"},
            "generation_focus": {
              "type": "array",
              "items": {"type": "string"}
            },
            "common_distractors": {
              "type": "array",
              "items": {"type": "string"}
            }
          }
        }
      }
    },
    "point": {
      "type": "object",
      "required": ["code", "label"],
      "additionalProperties": false,
      "properties": {
        "code": {"type": "string"},
        "label": {"type": "string"},
        "role": {
          "type": "string",
          "enum": ["primary", "secondary", "supporting", "unknown"]
        }
      }
    },
    "content_block": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["paragraph", "text", "formula", "image_ref", "line_break", "table"]
        },
        "text": {"type": "string"},
        "latex": {"type": "string"},
        "image_id": {"type": "string"},
        "alt": {"type": "string"}
      }
    },
    "option": {
      "type": "object",
      "required": ["label", "text"],
      "additionalProperties": false,
      "properties": {
        "label": {"type": "string"},
        "text": {"type": "string"}
      }
    },
    "image": {
      "type": "object",
      "required": ["type", "alt"],
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string"},
        "type": {
          "type": "string",
          "enum": ["svg", "image", "table", "other"]
        },
        "diagram_type": {
          "type": "string",
          "enum": ["geometry", "coordinate_graph", "circuit", "force_diagram", "statistical_chart", "table", "other"]
        },
        "alt": {"type": "string"},
        "code": {"type": "string"},
        "svg": {"type": "string"},
        "src": {"type": "string"},
        "semantic": {"type": "object"},
        "graph_schema": {"type": "object"}
      },
      "anyOf": [
        {"required": ["code"]},
        {"required": ["svg"]},
        {"required": ["src"]},
        {"required": ["semantic"]},
        {"required": ["graph_schema"]}
      ]
    }
  }
}
