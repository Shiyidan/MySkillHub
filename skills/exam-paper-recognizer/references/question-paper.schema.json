{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.codex.skills/exam-paper-recognizer/question-paper.schema.json",
  "title": "Exam Question Paper",
  "type": "object",
  "required": ["questions"],
  "additionalProperties": true,
  "properties": {
    "paper": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "exam": {"type": "string"},
        "year": {"type": ["integer", "string", "null"]},
        "section": {"type": ["string", "null"]},
        "language": {"type": "string"},
        "source_pdf": {"type": ["string", "null"]}
      }
    },
    "questions": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/question"}
    }
  },
  "$defs": {
    "question": {
      "type": "object",
      "required": ["number", "options"],
      "additionalProperties": true,
      "properties": {
        "number": {"type": "integer", "minimum": 1},
        "type": {
          "type": "string",
          "enum": ["single_choice", "multiple_choice", "numeric", "free_response", "unknown"]
        },
        "title": {"type": "string"},
        "stem": {"$ref": "#/$defs/content"},
        "options": {
          "type": "array",
          "items": {"$ref": "#/$defs/option"}
        },
        "answer": {
          "type": "array",
          "items": {"type": "string"}
        },
        "images": {
          "type": "array",
          "items": {"$ref": "#/$defs/asset"}
        },
        "assets": {
          "type": "array",
          "items": {"$ref": "#/$defs/asset"}
        },
        "knowledge_points": {
          "type": "array",
          "items": {"type": "string"}
        },
        "source": {"$ref": "#/$defs/source"},
        "confidence": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
        "validation_notes": {
          "type": "array",
          "items": {"type": "string"}
        }
      },
      "anyOf": [
        {"required": ["title"]},
        {"required": ["stem"]}
      ]
    },
    "option": {
      "type": "object",
      "required": ["label"],
      "additionalProperties": true,
      "properties": {
        "label": {"type": "string"},
        "text": {"type": "string"},
        "blocks": {
          "type": "array",
          "items": {"$ref": "#/$defs/block"}
        }
      },
      "anyOf": [
        {"required": ["text"]},
        {"required": ["blocks"]}
      ]
    },
    "content": {
      "type": "object",
      "required": ["blocks"],
      "additionalProperties": true,
      "properties": {
        "blocks": {
          "type": "array",
          "items": {"$ref": "#/$defs/block"}
        }
      }
    },
    "block": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": true,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["paragraph", "text", "formula", "asset", "table", "line_break"]
        },
        "text": {"type": "string"},
        "latex": {"type": "string"},
        "asset_id": {"type": "string"},
        "rows": {"type": "array"}
      }
    },
    "asset": {
      "type": "object",
      "required": ["id", "asset_type"],
      "additionalProperties": true,
      "properties": {
        "id": {"type": "string"},
        "asset_type": {
          "type": "string",
          "enum": [
            "image",
            "diagram",
            "geometry_diagram",
            "coordinate_graph",
            "circuit",
            "force_diagram",
            "statistical_chart",
            "table",
            "formula_image",
            "other"
          ]
        },
        "display": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "preferred": {"type": "string", "enum": ["svg", "image", "table", "latex"]},
            "svg_path": {"type": ["string", "null"]},
            "svg_code": {"type": ["string", "null"]},
            "fallback_image_path": {"type": ["string", "null"]},
            "source_crop_path": {"type": ["string", "null"]}
          }
        },
        "diagram_spec": {"type": ["object", "null"]},
        "semantic": {"type": ["object", "null"]},
        "graph_schema": {"type": ["object", "null"]},
        "alt": {"type": "string"},
        "quality": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "visual_similarity": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
            "semantic_confidence": {"type": ["number", "null"], "minimum": 0, "maximum": 1}
          }
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "pages": {
          "type": "array",
          "items": {"type": "integer", "minimum": 1}
        },
        "bbox": {
          "type": ["array", "null"],
          "items": {"type": "number"},
          "minItems": 4,
          "maxItems": 4
        },
        "page_image_path": {"type": ["string", "null"]},
        "source_pdf": {"type": ["string", "null"]}
      }
    }
  }
}
